{
    "name": "vapoursynth-preview",
    "displayName": "VapourSynth Preview",
    "description": "Recognize and preview VapourSynth (.vpy) scripts with vspreview, vspipe info and benchmark support",
    "version": "0.1.2",
    "publisher": "lapluis",
    "repository": {
        "type": "git",
        "url": "https://github.com/lapluis/vspreview-vscode"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/*.vpy"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "VapourSynth",
            "properties": {
                "vapoursynth.directory": {
                    "type": "string",
                    "default": "",
                    "description": "Path to VapourSynth installation directory (containing python.exe and vspipe.exe), e.g. C:\\tools\\vapoursynth"
                },
                "vapoursynth.pythonPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to Python executable. If empty, uses python.exe from the VapourSynth directory."
                }
            }
        },
        "commands": [
            {
                "command": "vapoursynth.preview",
                "title": "Preview (vspreview)",
                "icon": "$(preview)"
            },
            {
                "command": "vapoursynth.info",
                "title": "Script Info (vspipe -i)",
                "icon": "$(info)"
            },
            {
                "command": "vapoursynth.bench",
                "title": "Benchmark (vspipe -p)",
                "icon": "$(run-all)"
            },
            {
                "command": "vapoursynth.execInTerminal",
                "title": "Execute Script in Terminal"
            }
        ],
        "keybindings": [
            {
                "command": "vapoursynth.preview",
                "key": "ctrl+f5",
                "when": "editorTextFocus && resourceExtname == .vpy"
            },
            {
                "command": "vapoursynth.execInTerminal",
                "key": "ctrl+f6",
                "when": "editorTextFocus && resourceExtname == .vpy"
            },
            {
                "command": "vapoursynth.info",
                "key": "ctrl+f7",
                "when": "editorTextFocus && resourceExtname == .vpy"
            },
            {
                "command": "vapoursynth.bench",
                "key": "ctrl+f8",
                "when": "editorTextFocus && resourceExtname == .vpy"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "vapoursynth.preview",
                    "when": "resourceExtname == .vpy",
                    "group": "navigation@1"
                },
                {
                    "command": "vapoursynth.info",
                    "when": "resourceExtname == .vpy",
                    "group": "navigation@2"
                },
                {
                    "command": "vapoursynth.bench",
                    "when": "resourceExtname == .vpy",
                    "group": "navigation@3"
                }
            ]
        },
        "languages": [
            {
                "id": "python",
                "extensions": [
                    ".vpy"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "^18.0.0",
        "typescript": "^5.0.0"
    }
}